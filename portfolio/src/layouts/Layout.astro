---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Qickrapps — Modern Web Apps by Jasen Martin',
  description = 'A portfolio of modern, purpose-built web applications covering productivity, NDIS management, loyalty programs, and more.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Inter via Google Fonts (display=swap avoids render blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --font-sans: 'Inter', system-ui, sans-serif;
        --color-bg: #0f0f13;
        --color-surface: #18181f;
        --color-border: rgba(255,255,255,0.08);
        --color-text: #f1f1f3;
        --color-muted: #9ca3af;
        --color-accent: #6366f1;
        --radius-card: 16px;
        --max-w: 1200px;
        --transition: 0.2s ease;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }

      img { max-width: 100%; display: block; }

      :focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 3px;
        border-radius: 4px;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>

