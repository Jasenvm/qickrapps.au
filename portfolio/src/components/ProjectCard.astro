---
interface Props {
  id: string;
  title: string;
  shortDescription: string;
  technologies: string[];
  status: 'live' | 'in-progress' | 'coming-soon';
  subdomainUrl: string | null;
  liveAppUrl?: string | null;
  featured: boolean;
  emoji: string;
  accentColor: string;
  highlights: string[];
}

const {
  title,
  shortDescription,
  technologies,
  status,
  subdomainUrl,
  liveAppUrl,
  featured,
  emoji,
  accentColor,
  highlights,
} = Astro.props;

const statusLabel: Record<string, string> = {
  live: 'Live',
  'in-progress': 'In Progress',
  'coming-soon': 'Coming Soon',
};

const statusClass: Record<string, string> = {
  live: 'status--live',
  'in-progress': 'status--progress',
  'coming-soon': 'status--soon',
};

const primaryUrl = subdomainUrl ?? liveAppUrl ?? null;
---

<article class:list={['card', { 'card--featured': featured }]} style={`--accent: ${accentColor};`}>
  <div class="card__accent-bar" aria-hidden="true"></div>

  <div class="card__header">
    <span class="card__emoji" role="img" aria-label={title}>{emoji}</span>
    <span class:list={['status', statusClass[status]]}>{statusLabel[status]}</span>
  </div>

  <h2 class="card__title">{title}</h2>
  <p class="card__desc">{shortDescription}</p>

  {highlights.length > 0 && (
    <ul class="card__highlights">
      {highlights.slice(0, 3).map((h) => (
        <li>{h}</li>
      ))}
    </ul>
  )}

  {technologies.length > 0 && (
    <div class="card__tech" role="list" aria-label="Technologies">
      {technologies.map((t) => (
        <span role="listitem" class="tech-badge">{t}</span>
      ))}
    </div>
  )}

  <div class="card__footer">
    {primaryUrl ? (
      <a href={primaryUrl} class="btn btn--primary" target="_blank" rel="noopener noreferrer">
        View Project →
      </a>
    ) : (
      <span class="btn btn--disabled" aria-disabled="true">Coming Soon</span>
    )}
  </div>
</article>

<style>
  .card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.4);
    border-color: var(--accent);
  }

  .card--featured { border-color: rgba(255,255,255,0.12); }

  .card__accent-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    border-radius: var(--radius-card) var(--radius-card) 0 0;
  }

  .card__header { display: flex; align-items: center; justify-content: space-between; }

  .card__emoji { font-size: 2rem; line-height: 1; }

  .status {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
  }
  .status--live    { background: rgba(16,185,129,0.15); color: #34d399; }
  .status--progress{ background: rgba(245,158,11,0.15);  color: #fbbf24; }
  .status--soon    { background: rgba(156,163,175,0.15); color: #9ca3af; }

  .card__title { font-size: 1.25rem; font-weight: 700; line-height: 1.3; }
  .card__desc  { font-size: 0.9rem; color: var(--color-muted); line-height: 1.55; flex: 1; }

  .card__highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .card__highlights li {
    font-size: 0.82rem;
    color: var(--color-muted);
    padding-left: 16px;
    position: relative;
  }
  .card__highlights li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tech-badge {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--color-muted);
    white-space: nowrap;
  }

  .card__footer { margin-top: auto; padding-top: 8px; }

  .btn {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 10px;
    transition: background var(--transition), opacity var(--transition);
  }
  .btn--primary {
    background: var(--accent);
    color: #fff;
  }
  .btn--primary:hover { opacity: 0.85; }
  .btn--disabled {
    background: rgba(255,255,255,0.06);
    color: var(--color-muted);
    cursor: not-allowed;
  }
</style>

